{
  "version": 2,
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "vite",
  "functions": {
    "artifacts/api-server/dist/**/*.mjs": {
      "runtime": "nodejs@20.x",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "artifacts/api-server/dist/index.mjs"
    }
  ],
  "env": [
    {
      "key": "NODE_ENV",
      "value": "production"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
